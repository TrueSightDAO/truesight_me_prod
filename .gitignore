# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Dependencies - NEVER commit node_modules
node_modules/
**/node_modules/

# Lock files - package-lock.json SHOULD be committed (for consistent installs)
# yarn.lock and pnpm-lock.yaml can be committed if using those package managers
# Uncomment if you want to exclude lock files:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-*

# Environment
.env
.env.local
.env.*.local

# Cloud credentials (never commit)
google-service-account.json
**/google-service-account.json
*service-account*.jsoncredentials/
